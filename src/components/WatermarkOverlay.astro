---
// Full-page diagonal "WORK IN PROGRESS" watermark, tiled site-wide.
// Purely decorative (aria-hidden, pointer-events none) — never blocks
// clicks or scrolling. Controlled by the same SITE_UNDER_CONSTRUCTION
// flag as ConstructionBanner.astro; remove both together once the site
// is finished.
const label = 'WORK IN PROGRESS';
const tiles = Array.from({ length: 80 });
---

<div
  aria-hidden="true"
  class="fixed inset-0 z-40 overflow-hidden pointer-events-none select-none"
>
  <div
    class="grid grid-cols-5 gap-x-12 gap-y-16 justify-items-center"
    style="position:absolute; top:-50%; left:-50%; width:200%; height:200%; transform:rotate(-28deg);"
  >
    {tiles.map(() => (
      <span class="text-navy/10 font-serif font-bold text-xl md:text-2xl whitespace-nowrap">
        {label}
      </span>
    ))}
  </div>
</div>
