---
// Institutional footer — deliberately plain and serious, per brand brief.
import { SITE, NAV_LINKS } from '../data/site';
---

<footer class="bg-navy-dark text-white/80 mt-24">
  <div class="max-w-6xl mx-auto px-6 py-12 grid gap-10 md:grid-cols-3">
    <div>
      <p class="flex items-center gap-2 font-serif text-lg text-white font-bold mb-2">
        <svg viewBox="0 0 96 96" class="w-5 h-5 text-white" aria-hidden="true">
          <path d="M48 8 L82 20 V46 C82 68 68 84 48 90 C28 84 14 68 14 46 V20 Z" fill="currentColor" />
          <path
            d="M32 48 L44 60 L66 36"
            stroke="#1F6F4A"
            stroke-width="7"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        </svg>
        {SITE.businessName}
      </p>
      <p class="text-sm leading-relaxed">
        Custom business tools for independent retailers, grocers, and distributors across
        Ontario, Canada.
      </p>
    </div>

    <div>
      <p class="text-white font-semibold mb-2 text-sm uppercase tracking-wide">Site</p>
      <ul class="space-y-1 text-sm">
        {NAV_LINKS.map((link) => (
          <li><a href={link.href} class="hover:text-forest-light transition-colors">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="text-white font-semibold mb-2 text-sm uppercase tracking-wide">Contact</p>
      <ul class="space-y-1 text-sm">
        <li>
          <a href={`mailto:${SITE.contactEmail}`} class="hover:text-forest-light transition-colors">
            {SITE.contactEmail}
          </a>
        </li>
        <li>{SITE.location}</li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-6xl mx-auto px-6 py-6 text-xs text-white/60">
      {SITE.businessName} &copy; {SITE.copyrightYear}. {SITE.registrationLine}.
    </div>
  </div>
</footer>
