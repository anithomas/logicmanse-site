---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';
---

<BaseLayout
  title="Contact"
  description="Request a free 15-minute process audit from Logicmanse Solutions. No obligation, no jargon."
>
  <section class="bg-navy text-white">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <h1 class="fade-in-up font-serif font-bold text-4xl md:text-5xl mb-4">Request Your Free Process Audit</h1>
      <p class="fade-in-up text-lg text-white/80 max-w-2xl mx-auto">
        Tell us a little about your store and how you currently handle inventory, invoices, or
        reporting. We'll reply within one business day to schedule your free 15-minute call.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-2xl mx-auto px-6 py-20">
      <!--
        GitHub Pages serves plain static files only — there's no server to
        receive a form submission. Rather than depending on a third-party
        form service, this form builds a pre-filled email (subject + body
        from what the visitor typed) and opens it in their own email app
        when they click submit. Zero external accounts, zero server code,
        works on any static host.
      -->
      <form
        id="contact-form"
        class="fade-in-up space-y-6 bg-slate-50 border border-slate-200 rounded-xl p-8"
      >
        <div>
          <label for="name" class="block text-sm font-semibold text-navy mb-1">Your Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full border border-slate-300 rounded-md px-4 py-3 focus:outline-none focus:ring-2 focus:ring-forest"
          />
        </div>

        <div>
          <label for="business" class="block text-sm font-semibold text-navy mb-1">Business Name</label>
          <input
            type="text"
            id="business"
            name="business"
            class="w-full border border-slate-300 rounded-md px-4 py-3 focus:outline-none focus:ring-2 focus:ring-forest"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-navy mb-1">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full border border-slate-300 rounded-md px-4 py-3 focus:outline-none focus:ring-2 focus:ring-forest"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-navy mb-1">
            What's your biggest paperwork headache right now?
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full border border-slate-300 rounded-md px-4 py-3 focus:outline-none focus:ring-2 focus:ring-forest"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-forest hover:bg-forest-light text-white font-semibold px-8 py-4 rounded-md transition-colors"
        >
          Request My Free 15-Minute Process Audit
        </button>

        <p class="text-xs text-slate-400 text-center">
          Clicking submit opens a pre-filled email in your own email app, addressed to us — nothing
          is sent to a third-party server. Your information is never sold or shared.
        </p>
      </form>

      <p class="fade-in-up text-center text-slate-500 text-sm mt-8">
        Prefer to email directly? Reach us at{' '}
        <a href={`mailto:${SITE.contactEmail}`} class="text-forest font-semibold hover:underline">
          {SITE.contactEmail}
        </a>
      </p>
    </div>
  </section>

  <script define:vars={{ contactEmail: SITE.contactEmail }}>
    // Builds a mailto: link from the form fields and opens it — this is the
    // entire "backend" for this form. No server, no third-party service.
    // If a visitor's device has no default email app configured, the
    // fallback "Prefer to email directly?" link above still works.
    const form = document.getElementById('contact-form');
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const name = form.querySelector('#name').value.trim();
      const business = form.querySelector('#business').value.trim();
      const email = form.querySelector('#email').value.trim();
      const message = form.querySelector('#message').value.trim();

      const subject = `Free Process Audit Request — ${business || name}`;
      const body =
        `Name: ${name}\n` +
        `Business: ${business || '(not provided)'}\n` +
        `Email: ${email}\n\n` +
        `Paperwork headache:\n${message}`;

      window.location.href =
        `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    });
  </script>
</BaseLayout>
