---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout
  title="About"
  description="Logicmanse Solutions Canada Inc. builds custom, jargon-free business tools for independent retailers and grocers across Ontario."
>
  <section class="bg-navy text-white">
    <div class="max-w-4xl mx-auto px-6 py-20 text-center">
      <h1 class="fade-in-up font-serif font-bold text-4xl md:text-5xl mb-4">About Logicmanse Solutions</h1>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 py-20 space-y-8">
      <!--
        TODO (Ani): replace with a real photo — you, your workspace, or
        the Ontario region you serve. Drop the file in /public/ and swap
        the src below.
      -->
      <div class="fade-in-up aspect-video rounded-xl border-2 border-dashed border-slate-300 flex items-center justify-center text-slate-400 text-sm">
        Add a photo here
      </div>

      <div class="fade-in-up">
        <h2 class="text-2xl font-serif font-bold text-navy mb-4">Why Logicmanse Solutions Exists</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          Logicmanse Solutions Canada Inc. was founded to solve one specific, unglamorous problem:
          independent retailers and grocers spend far too many hours fighting Excel spreadsheets
          instead of running their stores.
        </p>
        <p class="text-slate-600 leading-relaxed">
          We bring enterprise-grade data and process discipline to businesses that have always
          been told off-the-shelf software is their only option. When your store's numbers
          matter, you deserve tools built around how you actually work — not the other way
          around.
        </p>
      </div>

      <div class="fade-in-up">
        <h2 class="text-2xl font-serif font-bold text-navy mb-4">How We Work</h2>
        <p class="text-slate-600 leading-relaxed">
          We build tools around your existing process instead of asking you to change how you run
          your store. Everything is explained in plain English, tested with your real data before
          it goes live, and supported by a person you can call — not a help desk ticket.
        </p>
      </div>

      <div class="fade-in-up">
        <h2 class="text-2xl font-serif font-bold text-navy mb-4">Based in Ontario, Canada</h2>
        <p class="text-slate-600 leading-relaxed">
          Logicmanse Solutions Canada Inc. is a registered corporate entity based in Ontario,
          Canada, working with independent retailers and grocers across the province.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="max-w-3xl mx-auto px-6 py-20 text-center">
      <SectionHeading title="Let's Talk About Your Store" subtitle="A free 15-minute call is the easiest way to see if we're a fit." />
      <div class="fade-in-up">
        <CTAButton href="/contact/">Request a Free 15-Minute Process Audit</CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>
